-- ==================== THEME MENU ====================
local function OpenThemeMenu()
    local themeGui = Instance.new("ScreenGui")
    themeGui.Name = "ThemeSelector"
    themeGui.ResetOnSpawn = false
    themeGui.Parent = player:WaitForChild("PlayerGui")

    local themeFrame = Instance.new("Frame")
    themeFrame.Size = UDim2.new(0, 300, 0, 380)
    themeFrame.Position = UDim2.new(0.5, -150, 0.25, 0)
    themeFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    themeFrame.Active = true
    themeFrame.Draggable = true
    themeFrame.Parent = themeGui

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 32)
    title.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    title.Text = "Выберите тему"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextSize = 16
    title.Font = Enum.Font.SourceSansBold
    title.Parent = themeFrame

    local close = Instance.new("TextButton")
    close.Size = UDim2.new(0, 32, 0, 32)
    close.Position = UDim2.new(1, -32, 0, 0)
    close.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    close.Text = "X"
    close.TextColor3 = Color3.fromRGB(255, 255, 255)
    close.TextSize = 14
    close.Font = Enum.Font.SourceSansBold
    close.Parent = themeFrame

    close.MouseButton1Click:Connect(function()
        themeGui:Destroy()
    end)

    local y = 45
    for name, colors in pairs(Themes) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -20, 0, 36)
        btn.Position = UDim2.new(0, 10, 0, y)
        btn.BackgroundColor3 = colors.Button
        btn.Text = name
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 15
        btn.Font = Enum.Font.SourceSansBold
        btn.Parent = themeFrame

        btn.MouseButton1Click:Connect(function()
            ApplyTheme(name)
            savePositions()
            themeGui:Destroy()
        end)

        y = y + 42
    end
end

themeBtn.MouseButton1Click:Connect(OpenThemeMenu)

-- ==================== BUTTON FUNCTIONS ====================
startBtn.MouseButton1Click:Connect(function()
    statusLabel.Text = "Кликни на кнопку Start..."
    local conn
    conn = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            getgenv().AutoFarm.StartPos = {X = input.Position.X, Y = input.Position.Y}
            savePositions()
            statusLabel.Text = "Start координаты сохранены!"
            conn:Disconnect()
        end
    end)
end)

